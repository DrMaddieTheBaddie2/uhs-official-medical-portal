# UHS Medical Portal — server-side environment variables (Discord OAuth2)
#
# Copy to .env and fill in real values. NEVER commit .env.
# NONE of these may be prefixed with VITE_ — that would expose them to the
# browser bundle. They are read only by the backend/serverless functions.

# From the Discord Developer Portal → your application → OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Must exactly match a redirect configured in the Discord Developer Portal,
# e.g. http://localhost:5173/api/auth/discord/callback (dev)
#      https://your-domain/api/auth/discord/callback (production)
DISCORD_REDIRECT_URI=

# The UHS Discord server id (enable Developer Mode in Discord → right-click
# the server → Copy Server ID). Used with the guilds.members.read scope to
# fetch the member's server nickname.
DISCORD_GUILD_ID=

# Long random string used to sign/encrypt the session cookie.
# Generate with: node -e "console.log(crypto.randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Public origin of the app, used for redirects after login/logout,
# e.g. http://localhost:5173 (dev) or https://your-domain (production)
APP_URL=
